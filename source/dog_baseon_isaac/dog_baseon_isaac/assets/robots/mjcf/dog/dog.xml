<mujoco model="simulate_dog_01">
  <!-- <compiler angle="radian"/>
  <option timestep="0.002" gravity="0 0 -9.81" /> -->

  <default class="main">
    <default class="hip_joint_range">
      <joint type="hinge" limited="auto"  armature="0.002" frictionloss="0.09" />
      <position ctrlrange="-0.62 0.62" forcelimited="auto" forcerange="-20 20" kp="30." kv="1." />
    </default>
    <default class="thigh_joint_range">
      <joint type="hinge" limited="auto"  armature="0.002" frictionloss="0.09" />
      <position ctrlrange="-2. 1." forcelimited="auto" forcerange="-20 20" kp="30." kv="1." />
    </default>
    <default class="calf_joint_range">
      <joint type="hinge" limited="auto"  armature="0.002" frictionloss="0.09" />
      <position ctrlrange="0 2." forcelimited="auto" forcerange="-20 20" kp="30." kv="1." />
    </default>

    <default class="sensor_site">
      <site type="sphere" size="0.023" rgba="1 0 1 0.2" />
    </default>

    <default class="contype1">
      <geom contype="2" conaffinity="1" friction="1.2 0.005 0.0005" margin="0.002" condim="4" />
    </default>
    <default class="contype2">
      <geom contype="4" conaffinity="1" friction="1.2 0.005 0.0005" margin="0.002" condim="4" />
    </default>
    <default class="contype3">
      <geom contype="8" conaffinity="1" friction="1.2 0.005 0.0005" margin="0.002" condim="4" />
    </default>
  </default>

  <asset>
    <texture name="_plane" type="2d" builtin="checker" rgb1=".1 .1 .1" rgb2=".4 .4 .4"
        width="512" height="512" mark="cross" markrgb=".8 .8 .8" />
    <material name="_plane" reflectance="0.3" texture="_plane" texrepeat="1 1" texuniform="true" />

    <mesh name="base_link" file="meshes/base_link.STL"/>
    <mesh name="FL_hip_Link" file="meshes/FL_hip_Link.STL"/>
    <mesh name="FL_thigh_Link" file="meshes/FL_thigh_Link.STL"/>
    <mesh name="FL_calf_Link" file="meshes/FL_calf_Link.STL"/>
    <mesh name="FR_hip_Link" file="meshes/FR_hip_Link.STL"/>
    <mesh name="FR_thigh_Link" file="meshes/FR_thigh_Link.STL"/>
    <mesh name="FR_calf_Link" file="meshes/FR_calf_Link.STL"/>
    <mesh name="RL_hip_Link" file="meshes/RL_hip_Link.STL"/>
    <mesh name="RL_thigh_Link" file="meshes/RL_thigh_Link.STL"/>
    <mesh name="RL_calf_Link" file="meshes/RL_calf_Link.STL"/>
    <mesh name="RR_hip_Link" file="meshes/RR_hip_Link.STL"/>
    <mesh name="RR_thigh_Link" file="meshes/RR_thigh_Link.STL"/>
    <mesh name="RR_calf_Link" file="meshes/RR_calf_Link.STL"/>
  </asset>

  <worldbody>
