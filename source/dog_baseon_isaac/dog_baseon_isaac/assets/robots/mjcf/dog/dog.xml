  <sensor>
    <jointpos name="FL_hip_joint_p" joint="FL_hip_joint" />
    <jointpos name="FR_hip_joint_p" joint="FR_hip_joint" />
    <jointpos name="RL_hip_joint_p" joint="RL_hip_joint" />
    <jointpos name="RR_hip_joint_p" joint="RR_hip_joint" />
    <jointpos name="FL_thigh_joint_p" joint="FL_thigh_joint" />
    <jointpos name="FR_thigh_joint_p" joint="FR_thigh_joint" />
    <jointpos name="RL_thigh_joint_p" joint="RL_thigh_joint" />
    <jointpos name="RR_thigh_joint_p" joint="RR_thigh_joint" />
    <jointpos name="FL_calf_joint_p" joint="FL_calf_joint" />
    <jointpos name="FR_calf_joint_p" joint="FR_calf_joint" />
    <jointpos name="RL_calf_joint_p" joint="RL_calf_joint" />
    <jointpos name="RR_calf_joint_p" joint="RR_calf_joint" />

    <jointvel name="FL_hip_joint_v"   joint="FL_hip_joint" />
    <jointvel name="FR_hip_joint_v"   joint="FR_hip_joint" />
    <jointvel name="RL_hip_joint_v"   joint="RL_hip_joint" />
    <jointvel name="RR_hip_joint_v"   joint="RR_hip_joint" />
    <jointvel name="FL_thigh_joint_v" joint="FL_thigh_joint" />
    <jointvel name="FR_thigh_joint_v" joint="FR_thigh_joint" />
