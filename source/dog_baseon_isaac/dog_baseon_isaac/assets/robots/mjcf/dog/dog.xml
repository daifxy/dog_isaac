    <jointvel name="FR_calf_joint_v"  joint="FR_calf_joint" />
    <jointvel name="RL_calf_joint_v"  joint="RL_calf_joint" />
    <jointvel name="RR_calf_joint_v"  joint="RR_calf_joint" />

    <framequat name='orientation' objtype='site' objname='imu' />
    <gyro  name='base_ang_vel' site='imu' />
    <velocimeter name="base_lin_vel" site="imu" />/
    <accelerometer name="base_acc" site="imu" />
    <touch name="FL_calf_joint_contact" site="FL_contact" />
