            <inertial pos="0.0856713 0.00430288 0.0081866" quat="0.474458 0.522417 0.464803 0.534723" mass="0.031705" diaginertia="0.000146436 0.000143832 3.43128e-06"/>
            <joint name="FR_calf_joint" pos="0 0 0" axis="0 1 0" class="calf_joint_range"/>
            <geom type="mesh" rgba="0.5 0.5 0.5 1" mesh="FR_calf_Link" class="contype1"/>
          </body>
        </body>
      </body>
      <body name="RL_hip_Link" pos="-0.159 0.03825 -0.056">
        <inertial pos="-0.0515793 -0.00176403 9.87843e-05" quat="0.497372 0.50216 0.502621 0.497825" mass="0.347657" diaginertia="0.0002376 0.000159503 0.000128197"/>
